# VPN Service Provider (mullvad, protonvpn, wireguard)
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard

# WireGuard Configuration
# Get these from your VPN provider's WireGuard config generator
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=

# Server Selection (optional filters)
# Format: comma-separated list of countries/regions/cities
SERVER_COUNTRIES=Canada
SERVER_REGIONS=
SERVER_CITIES=Toronto,Montreal,Vancouver,Calgary
SERVER_HOSTNAMES=

# OpenVPN (for protonvpn or custom OpenVPN providers)
OPENVPN_USER=
OPENVPN_PASSWORD=

# HTTP Proxies (comma or newline separated)
# Format: http://user:pass@ip:port or http://ip:port
PROXIES=

# Minecraft Accounts (email:password format, comma or newline separated)
# Gift Code accounts
GC_ACCOUNTS=
# GamePass accounts
GP_ACCOUNTS=
# Microsoft accounts
MS_ACCOUNTS=

# VPN Rotator Configuration
VPN_MAX_REQUESTS_PER_REGION=25
VPN_MIN_ROTATION_INTERVAL=5s
VPN_DETECT_ON_429=true
VPN_PREDICTIVE=true
VPN_FALLBACK_TO_PROXIES=true
VPN_MAX_RATELIMIT_HITS=2
VPN_PREDICTIVE_THRESHOLD=80